{
    {# Convert an incoming SfB/Skype-for-Business GRUU-style Focus dial-in into an  #}
    {# ad-hoc Pexip VMR that automatically dials back into the SfB meeting as an   #}
    {# MS-SIP participant. Video endpoints land in the VMR (with a real mixed      #}
    {# layout) while a single merged stream is sent into SfB.                      #}
    {#                                                                              #}
    {# Trade-offs:                                                                  #}
    {#   + Better A/V quality between VC endpoints; lower HW cost than per-call GW.#}
    {#   - SfB users see one merged participant; no roster control of VC endpoints.#}
    {#                                                                              #}
    {# Review every line tagged `pexCheck` before deploying.                        #}

    {#{pex_debug_log("##### call_info #####",     call_info) }#}
    {#{pex_debug_log("##### service_config #####", service_config) }#}

    {% set s4buser   = call_info.local_alias|pex_regex_replace('^sip:(.+)@(.+);gruu;opaque=app:conf:focus:id:([a-z0-9A-Z]+)', '\\1') %}
    {% set s4bdomain = call_info.local_alias|pex_regex_replace('^sip:(.+)@(.+);gruu;opaque=app:conf:focus:id:([a-z0-9A-Z]+)', '\\2') %}
    {% set s4bgruu   = call_info.local_alias|pex_regex_replace('^sip:(.+)@(.+);gruu;opaque=app:conf:focus:id:([a-z0-9A-Z]+)', '\\3') %}

    {% if ";gruu;opaque=app:conf:focus:id:" in call_info.local_alias %}
        {{pex_debug_log("Matched SfB Focus GRUU — building ad-hoc VMR for user", s4buser, "domain", s4bdomain, "gruu", s4bgruu, "from", call_info.remote_alias) }}

        "action" : "continue",
        "result" : {
            "service_type" : "conference",
            "name"         : "{{s4buser}}@{{s4bdomain}} Skype Meeting ({{s4bgruu}})",   {# pexCheck: VMR name format        #}
            "service_tag"  : "Triggered by {{call_info.remote_alias}} ({{call_info.protocol}}) - {{s4buser}} - {{s4bgruu}}",
            "description"  : "{{s4buser}} ({{s4bgruu}}) - trigger {{call_info.remote_alias}} ({{call_info.protocol}})",

            {# pexCheck: set a long random PIN + allow_guests=true if VC endpoints  #}
            {# should not join until the first SfB user lets them in.               #}
            "pin"          : "",
            "allow_guests" : false,
            "guest_pin"    : "",

            {# pexCheck: uncomment to play entry/exit tones                         #}
            {# "ivr_theme_name" : "Pexip theme (English_US) with entry tones",     #}

            "view" : "one_main_seven_pips",   {# pexCheck: merged-VMR layout       #}

            "automatic_participants" : [{
                "remote_alias"            : "{{call_info.local_alias}}",
                "local_alias"             : "VMR-{{s4buser}}",   {# pexCheck       #}
                "local_display_name"      : "VC",                {# pexCheck       #}
                "description"             : "ADP to SfB",
                "protocol"                : "mssip",
                "routing"                 : "manual",
                "role"                    : "guest",             {# pexCheck       #}
                "keep_conference_alive"   : "keep_conference_alive_never",
                "system_location_name"    : "Location A"
            }]
        }
    {% else %}
        {# Not an SfB GRUU dial-in — fall back to normal service-config handling.  #}
        {% if service_config %}
            "action" : "continue",
            "result" : {{service_config|pex_to_json}}
        {% else %}
            "action" : "reject",
            "result" : {}
        {% endif %}
    {% endif %}
}
