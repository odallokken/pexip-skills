{
    {# Force `enable_overlay_text=true` for EVERY service that resolves.           #}
    {# Quick fallback when you do not want to toggle the field per-VMR.            #}

    {% if service_config %}
        "action" : "continue",
        "result" : {{service_config|pex_update({"enable_overlay_text": true})|pex_to_json}}
    {% else %}
        "action" : "reject",
        "result" : {}
    {% endif %}
}
