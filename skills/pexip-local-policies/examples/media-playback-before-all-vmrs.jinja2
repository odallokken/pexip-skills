{
    {#-------------------------------------------------------------------------#}
    {#  Media playback before EVERY Virtual Meeting Room                       #}
    {#                                                                         #}
    {#  Policy type : Service Configuration (Call control > Policy profiles)   #}
    {#  Effect      : When a user dials the SIP alias of any VMR, Pexip first  #}
    {#                joins them to a media_playback service that plays a      #}
    {#                video/audio playlist. On playback completion the caller  #}
    {#                is transferred automatically into the real VMR.          #}
    {#                                                                         #}
    {#  How the loop is broken                                                 #}
    {#  -----------------------                                                #}
    {#  After the playback service completes, the caller is transferred back   #}
    {#  to the SAME alias they originally dialled. On that second policy       #}
    {#  invocation we detect the transfer using `call_info.previous_service_  #}
    {#  name`, which holds the name of the service the call was in before the  #}
    {#  transfer. We give the playback service a recognisable name prefix      #}
    {#  (PLAYBACK_NAME_PREFIX) and use that prefix as our loop-break sentinel. #}
    {#                                                                         #}
    {#  No routing-rule changes are required on the Management Node.           #}
    {#                                                                         #}
    {#  Auth handling                                                          #}
    {#  -------------                                                          #}
    {#  PIN and IdP are NOT propagated to the playback service. The playback   #}
    {#  service runs unauthenticated and the PIN / SSO prompt happens once,   #}
    {#  cleanly, at the real VMR after the transfer completes. (Propagating    #}
    {#  the PIN forced the caller to enter it twice — once for playback and    #}
    {#  again when joining the real VMR.)                                      #}
    {#                                                                         #}
    {#  Tweakables                                                             #}
    {#  ---------                                                              #}
    {#    PLAYBACK_NAME_PREFIX : prefix prepended to the playback service's    #}
    {#                           `name`. The same prefix is used to detect    #}
    {#                           the post-transfer leg via                    #}
    {#                           `call_info.previous_service_name`.            #}
    {#    PLAYLIST_ID          : numeric ID of the Media Playlist configured  #}
    {#                           under Call control > Media playlists.        #}
    {#-------------------------------------------------------------------------#}

    {% set PLAYBACK_NAME_PREFIX = "vmr-preroll:" %}
    {% set PLAYLIST_ID          = 1 %}

    {% set bare_alias = call_info.local_alias|pex_regex_replace("^sip:", "") %}

    {% set prev = call_info.previous_service_name|default("", true) %}
    {% set is_post_playback_leg = prev.startswith(PLAYBACK_NAME_PREFIX) %}

    {% if service_config %}
        {{ pex_debug_log("vmr-preroll policy", call_info, service_config) }}

        {#-- Only intercept on inbound dial-in to a real VMR (conference),  --#}
        {#-- and only if this is NOT the post-playback transfer leg.        --#}
        {% if call_info.call_direction == 'dial_in'
              and service_config.service_type == 'conference'
              and not is_post_playback_leg %}

            "action" : "continue",
            "result" : {
                "name"           : "{{ PLAYBACK_NAME_PREFIX }} {{ bare_alias }}",
                "service_type"   : "media_playback",
                "service_tag"    : "vmr-preroll",
                "media_playlist" : {{ PLAYLIST_ID }},
                "on_completion"  : "{\"transfer\": {\"conference\": \"{{ bare_alias }}\", \"role\": \"auto\"}}"
            }

        {% else %}
            {#-- Post-transfer leg, dial-outs, or non-VMR services: passthrough. --#}
            "action" : "continue",
            "result" : {{ service_config|pex_to_json }}
        {% endif %}

    {% else %}
        {#-- Alias not found / no service config: reject. --#}
        "action" : "reject",
        "result" : {}
    {% endif %}
}
